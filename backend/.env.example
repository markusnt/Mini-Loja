# Copie este arquivo para .env e preencha com os valores do seu ambiente:
# cp .env.example .env

# PostgreSQL — conexão usada pelo Prisma (ORM) e migrations
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO?schema=public
DATABASE_URL="postgresql://usuario:senha@localhost:5432/desafio_ntt?schema=public"

# Redis — cache e dados em memória (ioredis)
# Formato: redis://HOST:PORTA
REDIS_URL="redis://localhost:6379"

# Porta em que a API NestJS será exposta
PORT=3000

# URL do frontend — usada na configuração de CORS
FRONTEND_URL="http://localhost:5173"
